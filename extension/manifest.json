{
  "manifest_version": 3,
  "name": "YouTube Downloader MP4",
  "version": "1.0.0",
  "description": "Pobiera film z YouTube jako plik MP4 do folderu Pobrane jednym kliknieciem.",
  "key": "",
  "permissions": ["nativeMessaging", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Downloader MP4"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
